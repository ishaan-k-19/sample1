# ─── Shopify Storefront API ───────────────────────────────────────────────────
# Your Shopify store domain (e.g. "my-store.myshopify.com")
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API Access Token
# Create at: Shopify Admin → Settings → Apps and sales channels → Develop apps
# → Create an app → Configure Storefront API scopes:
#   - unauthenticated_read_product_listings
#   - unauthenticated_write_checkouts
#   - unauthenticated_read_checkouts
#   - unauthenticated_write_customers
#   - unauthenticated_read_customer_tags
# → Install app → Copy the Storefront API access token
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token_here
